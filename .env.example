# Port to run the proxy server on (default: 8081)
SIMPLE_PORT=8081

# URL of the OAI API server to proxy requests to (default: http://localhost:8080)
SIMPLE_OAI_API_SERVER_URL='http://localhost:8080'

# The hash of the Admin API key for managing users
SIMPLE_ADMIN_API_KEY_HASH='the-hash-of-your-admin-key-here'

# Path to the data directory where the database will be stored (default: ./data relative to executable)
SIMPLE_DATA_PATH='./data'

# for `just` recipes, interacting with the running server
SERVER_URL='http://localhost:8081'
ADMIN_KEY='sk-your-admin-key-here'
USER_KEY='sk-your-user-key-here'
