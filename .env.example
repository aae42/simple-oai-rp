# Llama Server Configuration
LLAMA_SERVER_URL=http://localhost:8080

# Proxy Server Configuration
PORT=8081

# Admin API Key (generate a secure random key)
# If not set, a random key will be generated and printed on startup
ADMIN_API_KEY=sk-admin-change-this-to-a-secure-random-key

# Database Path
DB_PATH=./proxy.db
